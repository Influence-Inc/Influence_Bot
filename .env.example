# ===========================================
# INFLUENCE BOT - Environment Configuration
# ===========================================

# --- ReelStats API ---
BOT_TOKEN=your-reelstats-bot-token
REELSTATS_API_URL=https://campaign.influence.technology

# --- Slack Configuration ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Fallback channel — used when a per-type channel below is unset.
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Per-notification-type channels. Each accepts either a channel name
# (e.g. "#content-reviews") or a channel ID (e.g. "C0XXXXXXXXX").
# The bot must be a member of each channel or posts fail with `not_in_channel`.
# Resolution order: env var → SLACK_CHANNEL_ID → hardcoded default in config.py.
SLACK_CHANNEL_REVIEWS=#content-reviews           # review_submitted webhook
SLACK_CHANNEL_UPLOADS=#content-uploads           # video_links_submitted + upload follow-ups
SLACK_CHANNEL_PAYMENTS=#payment-reminders        # deliverables-complete + daily payment summary
SLACK_CHANNEL_MILESTONES=#breakout-content-alerts # view milestones (250K, 500K, 1M, ...)
SLACK_CHANNEL_DEADLINES=#creator-deadlines       # deadline reminders (3d / 1d / overdue)

# --- Email Configuration (jennifer@useinfluence.xyz) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=jennifer@useinfluence.xyz
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Jennifer - INFLUENCE

# --- Application ---
# Port binding is handled by the process manager (gunicorn on Railway reads
# $PORT automatically), so APP_HOST / APP_PORT are no longer needed.
#
# DATABASE_URL default is the local SQLite file. On Railway, mount a
# Volume at /data and set the four-slash absolute form below:
#   DATABASE_URL=sqlite:////data/influence_bot.db
DATABASE_URL=sqlite:///influence_bot.db
# Safety-net fallback poll cadence (real-time notifications arrive via
# ReelStats webhooks). POLL_INTERVAL_MINUTES is accepted for backwards
# compatibility but POLL_INTERVAL_SECONDS wins if both are set.
POLL_INTERVAL_SECONDS=60

# --- Testing ---
# If set, the bot only processes the campaign with this exact name.
# Leave empty in production to process all campaigns.
# TEST_CAMPAIGN_NAME=Dummy testing
